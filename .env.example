NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Bypasses Row Level Security.
# Never prefix with NEXT_PUBLIC_ and never import it into client code.
SUPABASE_SERVICE_ROLE_KEY=

# Discord OAuth — used by supabase/config.toml env-substitution for LOCAL dev.
# The hosted project reads these from the Supabase dashboard, not this file.
SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=
